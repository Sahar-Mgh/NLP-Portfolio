# Portfolio-root ignores. Each deliverable folder (e.g. capstone/) keeps its own
# .gitignore for its data-specific rules — capstone/.gitignore excludes the real,
# sensitive participant data so it is never committed.

# Python
__pycache__/
*.py[cod]

# Virtual environments
.venv/
venv/
env/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
